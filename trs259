def update_status_bar(start_val, end_val, session_data, pending_data, duration_filter, event_filter):
    """Update the status bar with current session information."""
    
    # Default values
    shift_icon = "🔵"
    shift_name = "SHIFT A"
    shift_time = ""
    event_count = "0"
    cache_icon = "⚡"
    cache_text = "Fresh"
    cache_style = {"fontWeight": "600", "color": "#38a169", "fontSize": "10px"}
    cache_pct = "100%"
    cache_pct_style = {"fontWeight": "700", "color": "#38a169", "fontSize": "10px", "marginLeft": "4px"}
    cache_time = ""
    pending_count = "0 unsaved"
    pending_style = {"fontWeight": "600", "color": "#718096", "fontSize": "10px"}
    
    try:
        # Parse shift info from datetime inputs
        if start_val:
            start_dt = pd.to_datetime(start_val)
            end_dt = pd.to_datetime(end_val) if end_val else start_dt + datetime.timedelta(hours=12)
            
            # Determine shift type
            if start_dt.hour == Config.SHIFT_A_START:
                shift_icon = "🔵"
                shift_name = "SHIFT A"
            elif start_dt.hour == Config.SHIFT_B_START:
                shift_icon = "🔶"
                shift_name = "SHIFT B"
            else:
                shift_icon = "⚪"
                shift_name = "CUSTOM"
            
            # Format time range
            shift_time = f"{start_dt.strftime('%b %d')} • {start_dt.strftime('%H:%M')}-{end_dt.strftime('%H:%M')}"
        
        # Count events from session data
        if session_data and session_data != "{}":
            df = pd.read_json(session_data, orient='split')
            
            # Apply same filters as the table to get accurate count
            if duration_filter is not None:
                duration_numeric = pd.to_numeric(df.get(Config.DURATION_COL, 0), errors='coerce')
                # Include ongoing events (EndTime starts with "9999") regardless of duration
                is_ongoing = df[Config.END_TIME_COL].astype(str).str.startswith("9999")
                df = df[(duration_numeric > duration_filter) | is_ongoing]
            
            if event_filter and event_filter != "ALL":
                df = df[df.get(Config.EVENT_COL, "").str.upper() == event_filter.upper()]
            
            if start_val and end_val:
                df["_tmp_start"] = df[Config.START_TIME_COL].apply(
                    lambda x: pd.to_datetime(str(x).split(" - ")[0].strip()) if pd.notna(x) else pd.NaT
                )
                df = df[(df["_tmp_start"] >= start_dt) & (df["_tmp_start"] < end_dt)]
            
            event_count = str(len(df))
        
        # Cache status with percentage
        global _data_cache
        if _data_cache.get("timestamp"):
            age = datetime.datetime.now() - _data_cache["timestamp"]
            total_seconds = age.total_seconds()
            minutes = int(total_seconds / 60)
            seconds = int(total_seconds % 60)
            
            # Calculate freshness percentage (100% = just cached, 0% = expired)
            cache_ttl_seconds = CACHE_TTL_MINUTES * 60
            freshness = max(0, 100 - (total_seconds / cache_ttl_seconds) * 100)
            cache_pct = f"{int(freshness)}%"
            
            if minutes < CACHE_TTL_MINUTES:
                cache_icon = "⚡"
                cache_text = "Fresh"
                cache_style = {"fontWeight": "600", "color": "#38a169", "fontSize": "10px"}
                cache_pct_style = {"fontWeight": "700", "color": "#38a169", "fontSize": "10px", "marginLeft": "4px"}
                if minutes == 0:
                    cache_time = f"({seconds}s)"
                else:
                    cache_time = f"({minutes}m {seconds}s)"
            else:
                cache_icon = "⏳"
                cache_text = "Stale"
                cache_style = {"fontWeight": "600", "color": "#dd6b20", "fontSize": "10px"}
                cache_pct_style = {"fontWeight": "700", "color": "#dd6b20", "fontSize": "10px", "marginLeft": "4px"}
                cache_time = f"({minutes}m)"
        else:
            cache_icon = "❓"
            cache_text = "No cache"
            cache_pct = "0%"
            cache_style = {"fontWeight": "600", "color": "#a0aec0", "fontSize": "10px"}
            cache_pct_style = {"fontWeight": "700", "color": "#a0aec0", "fontSize": "10px", "marginLeft": "4px"}
            cache_time = ""
        
        # Pending changes count
        pending_dict = json.loads(pending_data) if pending_data else {}
        count = len(pending_dict)
        if count > 0:
            pending_count = f"{count} unsaved"
            pending_style = {"fontWeight": "700", "color": "#dd6b20", "fontSize": "10px"}
        else:
            pending_count = "All saved ✓"
            pending_style = {"fontWeight": "600", "color": "#38a169", "fontSize": "10px"}
            
    except Exception as e:
        logger.warning(f"Error updating status bar: {e}")
    
    return (shift_icon, shift_name, shift_time, event_count, 
            cache_icon, cache_text, cache_style, cache_pct, cache_pct_style, cache_time,
            pending_count, pending_style)


# =============================================================================
# HRxHR Save Callback
# =============================================================================
# Saves user inputs from HRxHR view (causes, actions, resolved, counts) to HRxHR_Data
@app.callback(
    Output("hrxhr-save-status", "children"),
    Input("save-hrxhr-btn", "n_clicks"),
    State("hrxhr-shift-info", "data"),
    State({"type": "hrxhr-primary", "hour": ALL}, "value"),
    State({"type": "hrxhr-primary", "hour": ALL}, "id"),
    State({"type": "hrxhr-secondary", "hour": ALL}, "value"),
    State({"type": "hrxhr-secondary", "hour": ALL}, "id"),
    State({"type": "hrxhr-causes", "hour": ALL}, "value"),
    State({"type": "hrxhr-causes", "hour": ALL}, "id"),
    State({"type": "hrxhr-actions", "hour": ALL}, "value"),
    State({"type": "hrxhr-actions", "hour": ALL}, "id"),
    State({"type": "hrxhr-resolved", "hour": ALL}, "value"),
    State({"type": "hrxhr-resolved", "hour": ALL}, "id"),
    State({"type": "hrxhr-custom", "hour": ALL}, "value"),
    State({"type": "hrxhr-custom", "hour": ALL}, "id"),
    State("hrxhr-custom-col-name", "value"),
    prevent_initial_call=True
)
def save_hrxhr_callback(n_clicks, shift_info, 
                        primary_vals, primary_ids,
                        secondary_vals, secondary_ids,
                        causes_vals, causes_ids,
                        actions_vals, actions_ids,
                        resolved_vals, resolved_ids,
                        custom_vals, custom_ids,
                        custom_col_name):
    """
    Saves HRxHR data when user clicks Save button.
    Collects all input values and saves to HRxHR_Data dataset.
    """
    if not n_clicks:
        raise PreventUpdate
    
    if not shift_info:
        return "❌ No shift info available"
    
    try:
        machine = shift_info.get("machine", "PGI")
        shift_date = shift_info.get("shift_date", "")
        shift_hours = shift_info.get("shift_hours", [])
        
        if not shift_date or not shift_hours:
            return "❌ Missing shift information"
        
        # Build hourly data dictionary from all inputs
        hourly_data = {}
        
        # Map primary counts
        for val, id_dict in zip(primary_vals, primary_ids):
            hour = id_dict.get("hour")
            if hour:
                if hour not in hourly_data:
                    hourly_data[hour] = {}
                hourly_data[hour]["primary_count"] = val
        
        # Map secondary counts
        for val, id_dict in zip(secondary_vals, secondary_ids):
            hour = id_dict.get("hour")
            if hour:
                if hour not in hourly_data:
                    hourly_data[hour] = {}
                hourly_data[hour]["secondary_count"] = val
        
        # Map causes
        for val, id_dict in zip(causes_vals, causes_ids):
            hour = id_dict.get("hour")
            if hour:
                if hour not in hourly_data:
                    hourly_data[hour] = {}
                hourly_data[hour]["causes"] = val if val else ""
        
        # Map actions
        for val, id_dict in zip(actions_vals, actions_ids):
            hour = id_dict.get("hour")
            if hour:
                if hour not in hourly_data:
                    hourly_data[hour] = {}
                hourly_data[hour]["actions"] = val if val else ""
        
        # Map resolved checkboxes
        for val, id_dict in zip(resolved_vals, resolved_ids):
            hour = id_dict.get("hour")
            if hour:
                if hour not in hourly_data:
                    hourly_data[hour] = {}
                # Checklist returns list like ["resolved"] or []
                hourly_data[hour]["resolved"] = "resolved" in (val or [])
        
        # Map custom column values (TL3/TL4/TL5 only)
        # Stored as separate columns: Custom_Value (numeric) + Custom_Column_Name (text)
        col_name = (custom_col_name or "CUSTOM").strip().upper() if custom_col_name else "CUSTOM"
        if custom_vals and custom_ids:
            for val, id_dict in zip(custom_vals, custom_ids):
                hour = id_dict.get("hour")
                if hour:
                    if hour not in hourly_data:
                        hourly_data[hour] = {}
                    # Store value and column name separately
                    if val is not None and str(val).strip():
                        hourly_data[hour]["custom_value"] = val
                        hourly_data[hour]["custom_col_name"] = col_name
                    else:
                        hourly_data[hour]["custom_value"] = None
                        hourly_data[hour]["custom_col_name"] = col_name
        
        # Add downtime_minutes (we don't have this from inputs, set to 0 - it's computed from events)
        for hour in hourly_data:
            if "downtime_minutes" not in hourly_data[hour]:
                hourly_data[hour]["downtime_minutes"] = 0
        
        # Save to dataset
        result = save_hrxhr_data(machine, shift_date, hourly_data)
        
        # Return status with timestamp
        now = datetime.datetime.now().strftime("%H:%M:%S")
        return f"{result} at {now}"
        
    except Exception as e:
        logger.error(f"Error in save_hrxhr_callback: {e}")
        import traceback
        traceback.print_exc()
        return f"❌ Error: {str(e)}"
