def get_reasons_for_machine(machine: str) -> list:
    """Returns the appropriate reasons list for a given machine."""
    if machine == "PGI":
        return PGI_REASONS
    elif machine in ["TL3", "TL4", "TL5"]:
        return TREAD_REASONS
    return REASONS  # Fallback to all reasons

def get_dropdown_options_for_machine(machine: str) -> list:
