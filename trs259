                html.Td(duration_display, style=duration_style),
                html.Td(reasons_block, style={**cell_style, "textAlign": "left"}),
                html.Td(comment_input, style=cell_style)
            ]
            
            table_rows.append(html.Tr(row_cells, style={"background": row_bg}))
        
        # Build complete table
        table = html.Table(
            [html.Thead(header), html.Tbody(table_rows)],
            style={"width": "100%", "borderCollapse": "collapse", "fontSize": "13px"}
        )
        
        # Summary header
