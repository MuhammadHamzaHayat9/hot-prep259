def extract_machine_from_composite_key(composite_key: str) -> str:
    """
    Extracts machine name from Composite_Key.
    Example: "PGI_PerformanceSLOW_2026-03-06 07:56:00" -> "PGI"
    """
    try:
        # Handle null/empty values
        if pd.isna(composite_key) or not composite_key:
            return "Unknown"
        # Split by underscore and take first part (machine name)
        # Composite_Key format: {Machine}_{EventType}_{Timestamp}
        parts = str(composite_key).split("_")
        return parts[0] if parts else "Unknown"
    except Exception as e:
        logger.warning(f"Error extracting machine from composite key: {e}")
        return "Unknown"


def is_ongoing_event(end_time) -> bool:
    """
    Checks if an event is ongoing (EndTime EST starts with "9999-").
    In the source data, ongoing events use "9999-12-31" as placeholder end time.
    """
    try:
        if pd.isna(end_time):
            return False
        # Events with end time starting with "9999" are still ongoing
        return str(end_time).startswith("9999")
    except Exception:
        return False


def extract_datetime_from_timestamp(ts) -> pd.Timestamp:
    """
    Converts a timestamp string into a pandas datetime object.
    Used for filtering and sorting events by time.
    """
    try:
        # Handle null values - return minimum timestamp for sorting
        if pd.isna(ts):
            return pd.Timestamp.min
        ts_str = str(ts)
        # Ongoing events (9999-*) should sort to the end
        if ts_str.startswith("9999"):
            return pd.Timestamp.max
        # Convert string to pandas Timestamp with error handling
        dt = pd.to_datetime(ts_str, errors='coerce')
        return dt if not pd.isna(dt) else pd.Timestamp.min
    except Exception as e:
        logger.warning(f"Error extracting datetime: {e}")
        return pd.Timestamp.min


def darken_color(hex_color: str, factor: float = 0.7) -> str:
    """
    Darkens a hex color by the given factor.
    Used for creating darker borders/buttons for category pills.
    factor < 1.0 = darker, factor > 1.0 = lighter
    """
    try:
        # Remove # prefix if present
        hex_color = hex_color.lstrip('#')
        # Extract RGB components and multiply by factor
        r = int(int(hex_color[0:2], 16) * factor)
        g = int(int(hex_color[2:4], 16) * factor)
        b = int(int(hex_color[4:6], 16) * factor)
        # Return formatted hex color
        return '#{:02X}{:02X}{:02X}'.format(r, g, b)
    except Exception:
        return hex_color


def format_duration_display(duration, end_time) -> str:
    """
    Formats duration for display. Shows "Ongoing" if event hasn't ended.
    """
    if is_ongoing_event(end_time):
        return "⏳ Ongoing"
    try:
        return f"{int(duration)} min"
    except (ValueError, TypeError):
        return str(duration)


