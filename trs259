def calculate_categorization_status(reason_durations_json: str, calculated_duration, end_time) -> str:
    """
    Calculates the categorization status based on allocated vs actual duration.
    
    Returns:
        - "Pending": Event is ongoing (no final duration yet)
        - "Complete": All time allocated (allocated == calculated)
        - "Partial": Some time unassigned (allocated < calculated)
        - "Over-allocated": Error - allocated > calculated
        - "Not Started": No categories assigned yet
    """
    # Check if event is ongoing
    if is_ongoing_event(end_time):
        return "Pending"
    
    # Check if calculated duration is available
    if pd.isna(calculated_duration) or calculated_duration is None:
        return "Pending"
    
    try:
        calc_dur = float(calculated_duration)
    except (ValueError, TypeError):
        return "Pending"
    
    # Calculate total allocated time
    total_allocated = 0
    try:
        if reason_durations_json and reason_durations_json != "nan" and reason_durations_json != "[]":
            allocations = json.loads(reason_durations_json)
            total_allocated = sum(float(a.get("duration", 0) or 0) for a in allocations)
        else:
            return "Not Started"
    except (json.JSONDecodeError, TypeError):
        return "Not Started"
    
    # Determine status
    if total_allocated == 0:
        return "Not Started"
    elif abs(total_allocated - calc_dur) < 0.5:  # Within 0.5 min tolerance
        return "Complete"
    elif total_allocated < calc_dur:
        return "Partial"
    else:
        return "Over-allocated"


def calculate_unallocated_minutes(reason_durations_json: str, calculated_duration) -> int:
    """
    Calculates unallocated minutes (duration not yet assigned to reasons).
    
    Returns: Integer of unallocated minutes, or None if duration unknown
    """
    if pd.isna(calculated_duration) or calculated_duration is None:
        return None
    
    try:
        calc_dur = float(calculated_duration)
    except (ValueError, TypeError):
        return None
    
    total_allocated = 0
    try:
        if reason_durations_json and reason_durations_json != "nan":
            allocations = json.loads(reason_durations_json)
            total_allocated = sum(float(a.get("duration", 0) or 0) for a in allocations)
    except (json.JSONDecodeError, TypeError):
        pass
    
    return max(0, int(calc_dur - total_allocated))


def get_status_indicator(status: str) -> dict:
    """
    Returns emoji and style for status indicator display.
    """
    indicators = {
        "Complete": {"emoji": "🟢", "color": "#38a169", "text": "Complete"},
        "Partial": {"emoji": "🟡", "color": "#d69e2e", "text": "Partial"},
        "Over-allocated": {"emoji": "🔴", "color": "#e53e3e", "text": "Over-allocated"},
        "Pending": {"emoji": "⏳", "color": "#ed8936", "text": "Ongoing"},
        "Not Started": {"emoji": "⚪", "color": "#718096", "text": "Not Started"}
    }
    return indicators.get(status, indicators["Not Started"])


