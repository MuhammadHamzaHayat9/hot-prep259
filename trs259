# =============================================================================
# Table Rendering Function
# =============================================================================
def render_events_table(df: pd.DataFrame, event_type_filter: str, duration_threshold: int,
                        start_dt: pd.Timestamp, end_dt: pd.Timestamp, machine_filter: str,
                        pending_changes: dict = None) -> html.Div:
    """
    Renders the main events table with columns:
    StartTime EST | Event | Recipe | Product_Width | Duration | Category Allocation | Comment
    
    pending_changes: dict of {composite_key: {Reasons, ReasonDurations, Comment}} for unsaved edits
    """
    pending_changes = pending_changes or {}
    try:
        # Apply filters with detailed logging for debugging
        filtered_df = df.copy()
        logger.info(f"[FILTER DEBUG] Starting with {len(filtered_df)} events, machine_filter={machine_filter}")
        logger.info(f"[FILTER DEBUG] Columns in df: {list(filtered_df.columns)}")
        
        # Machine filter
        if machine_filter and "Machine" in filtered_df.columns:
            unique_machines = filtered_df["Machine"].unique().tolist()
            logger.info(f"[FILTER DEBUG] Unique machines in data: {unique_machines}")
            filtered_df = filtered_df[filtered_df["Machine"] == machine_filter]
            logger.info(f"[FILTER DEBUG] After machine filter: {len(filtered_df)} events")
        else:
            logger.info(f"[FILTER DEBUG] Machine column not found or no filter applied")
        
        # Event type filter
        if event_type_filter and event_type_filter != "ALL" and Config.EVENT_COL in filtered_df.columns:
            filtered_df = filtered_df[filtered_df[Config.EVENT_COL].str.upper() == event_type_filter.upper()]
            logger.info(f"[FILTER DEBUG] After event type filter ({event_type_filter}): {len(filtered_df)} events")
        
        # Duration filter - but always include ongoing events (they have nan duration)
        if Config.DURATION_COL in filtered_df.columns:
            duration_numeric = pd.to_numeric(filtered_df[Config.DURATION_COL], errors='coerce')
            # Check if event is ongoing (EndTime starts with "9999")
            is_ongoing = filtered_df[Config.END_TIME_COL].astype(str).str.startswith("9999")
            # Keep events that pass duration filter OR are ongoing
            filtered_df = filtered_df[(duration_numeric > duration_threshold) | is_ongoing]
            logger.info(f"[FILTER DEBUG] After duration filter (>{duration_threshold}): {len(filtered_df)} events")
        
        # Date/time filter (end_dt is exclusive to avoid boundary overlap)
        # Shift A: 06:00 <= x < 18:00, Shift B: 18:00 <= x < 06:00 next day
        if Config.START_TIME_COL in filtered_df.columns:
            filtered_df["_parsed_start"] = filtered_df[Config.START_TIME_COL].apply(extract_datetime_from_timestamp)
            logger.info(f"[FILTER DEBUG] Date range: {start_dt} to {end_dt}")
            if len(filtered_df) > 0:
                logger.info(f"[FILTER DEBUG] Sample parsed times: {filtered_df['_parsed_start'].head(3).tolist()}")
            filtered_df = filtered_df[
                (filtered_df["_parsed_start"] >= start_dt) & 
                (filtered_df["_parsed_start"] < end_dt)
            ]
            logger.info(f"[FILTER DEBUG] After date/time filter: {len(filtered_df)} events")
            filtered_df = filtered_df.drop(columns=["_parsed_start"])
        
        # Sort by start time descending (newest first)
        if Config.START_TIME_COL in filtered_df.columns:
            filtered_df = filtered_df.sort_values(Config.START_TIME_COL, ascending=False)
        
        logger.info(f"Rendering table with {len(filtered_df)} events after filtering")
        
        if filtered_df.empty:
            # Show detailed debug info when no events found
            return html.Div([
                html.Div("📭", style={"fontSize": "48px", "marginBottom": "16px"}),
                html.Div("No events found for the selected filters", style={
                    "fontSize": "16px", "color": "#718096", "fontWeight": "500", "marginBottom": "16px"
                }),
                html.Div([
                    html.Div(f"🔧 Machine: {machine_filter}", style={"fontSize": "12px", "color": "#a0aec0"}),
                    html.Div(f"📅 Range: {start_dt.strftime('%Y-%m-%d %H:%M') if hasattr(start_dt, 'strftime') else start_dt} to {end_dt.strftime('%Y-%m-%d %H:%M') if hasattr(end_dt, 'strftime') else end_dt}", style={"fontSize": "12px", "color": "#a0aec0"}),
                    html.Div(f"⏱️ Duration: > {duration_threshold} min", style={"fontSize": "12px", "color": "#a0aec0"}),
                    html.Div(f"📊 Source data rows: {len(df)}", style={"fontSize": "12px", "color": "#a0aec0", "marginTop": "8px"}),
                ], style={"textAlign": "center"})
            ], style={"textAlign": "center", "padding": "60px 20px"})
        
        # Build table header - Event column has inline filter dropdown
        event_header = html.Div([
            html.Div("Event", style={"fontWeight": "700", "marginBottom": "6px"}),
            dcc.Dropdown(
                id="event-header-dropdown",
                options=[
                    {"label": "All", "value": "ALL"},
                    {"label": "🔴 Down", "value": "DOWNTIME"},
                    {"label": "🟠 Slow", "value": "SLOWTIME"}
                ],
                value=event_type_filter if event_type_filter else "ALL",
                clearable=False,
                style={"fontSize": "10px", "minWidth": "80px"}
