# =============================================================================
# CALLBACKS SECTION
# =============================================================================
# Dash callbacks handle all user interactions and data updates.
# Each callback connects UI components (Inputs) to outputs, triggered by user actions.
#
# Key patterns used:
#   - Pattern-matching callbacks: Use dicts like {"type": "...", "index": ALL}
#     to handle dynamic numbers of similar components (e.g., each event row)
#   - dcc.Store: Client-side storage for session data and pending changes
#   - prevent_initial_call: Prevents callback from running on page load
#   - allow_duplicate: Allows multiple callbacks to write to same Output
#
# Callback flow:
#   1. load_session_data - Loads initial data from Dataiku
#   2. update_table - Renders the main table/view based on filters
#   3. add_category/remove_category - Modify categories (pending changes)
#   4. save_single_row - Persist single row changes to Dataiku
#   5. save_all_changes - Persist all pending changes to Dataiku
# =============================================================================

# =============================================================================
# Session Data Loading Callback
# =============================================================================
# Loads event data from Dataiku and stores in browser session (dcc.Store)
# Triggered on: page load, refresh button click, or machine change
@app.callback(
    Output("session-data", "data"),
    Input("refresh-button", "n_clicks"),
    Input("combined-table", "id"),
    Input("machine-selector", "data"),
    prevent_initial_call=False
)
def load_session_data(n_clicks, _, machine):
    """
    Load event data into browser session storage.
    Data is serialized as JSON for client-side caching.
    Reloads when machine changes to get data from correct dataset.
    """
    # Default to PGI if no machine selected
    machine = machine or "PGI"
    logger.info(f"[LOAD SESSION] Loading session data for machine: {machine}")
    
    # Only load data for supported machines (PGI, TL3, and TL4)
    if machine not in ["PGI", "TL3", "TL4"]:
        logger.info(f"[LOAD SESSION] Machine {machine} not supported, returning empty")
        return "{}"
    
    df = load_events_data(machine)
    if df.empty:
        logger.warning(f"[LOAD SESSION] Loaded empty dataframe for {machine}")
        return "{}"
    
    logger.info(f"[LOAD SESSION] Loaded {len(df)} events for {machine}, columns: {list(df.columns)}")
    return df.to_json(date_format='iso', orient='split')


