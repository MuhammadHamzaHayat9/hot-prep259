def get_shift_range(ref: datetime.datetime) -> tuple:
    """
    Returns the start and end times of the shift and the shift type.
    Shift A: 6:00 AM to 6:00 PM (day shift)
    Shift B: 6:00 PM to 6:00 AM (night shift - crosses midnight)
    
    Returns: (shift_start, shift_end, shift_name)
    """
    try:
        # Check if reference time falls within Shift A (6 AM - 6 PM)
        if Config.SHIFT_A_START <= ref.hour < Config.SHIFT_B_START:
            # SHIFT A: Same day, 6 AM to 6 PM
            start = datetime.datetime.combine(ref.date(), datetime.time(Config.SHIFT_A_START, 0))
            end = datetime.datetime.combine(ref.date(), datetime.time(Config.SHIFT_B_START, 0))
            shift = "Shift A"
        else:
            # SHIFT B: Crosses midnight, need to handle date boundary
            if ref.hour >= Config.SHIFT_B_START:
                # Evening hours (6 PM - midnight): shift started today
                start = datetime.datetime.combine(ref.date(), datetime.time(Config.SHIFT_B_START, 0))
                end = datetime.datetime.combine(ref.date() + datetime.timedelta(days=1), datetime.time(Config.SHIFT_A_START, 0))
            else:
                # Early morning hours (midnight - 6 AM): shift started yesterday
                start = datetime.datetime.combine(ref.date() - datetime.timedelta(days=1), datetime.time(Config.SHIFT_B_START, 0))
                end = datetime.datetime.combine(ref.date(), datetime.time(Config.SHIFT_A_START, 0))
            shift = "Shift B"
        return start, end, shift
    except Exception as e:
        logger.error(f"Error determining shift range: {e}")
        now = datetime.datetime.now()
        return now, now, "Unknown"


def get_shift_by_index(shift_index: int) -> tuple:
    """
    Returns the shift boundaries and type for a given shift index offset.
    Used for Previous/Next shift navigation.
    
    shift_index:  0 = current shift
                 -1 = previous shift
                 +1 = next shift
    
    Returns: (shift_start, shift_end, shift_name)
    """
    try:
        now = datetime.datetime.now()
        # Get current shift's start time as reference point
        current_start, _, _ = get_shift_range(now)
        # Calculate target shift by adding/subtracting 12-hour blocks
        shift_start = current_start + datetime.timedelta(hours=Config.SHIFT_DURATION_HOURS * shift_index)
        shift_end = shift_start + datetime.timedelta(hours=Config.SHIFT_DURATION_HOURS)
        # Determine shift type based on start hour
        shift_type = "Shift A" if shift_start.hour == Config.SHIFT_A_START else "Shift B" if shift_start.hour == Config.SHIFT_B_START else "Unknown"
        return shift_start, shift_end, shift_type
    except Exception as e:
        logger.error(f"Error determining shift by index: {e}")
        now = datetime.datetime.now()
        return now, now, "Unknown"


