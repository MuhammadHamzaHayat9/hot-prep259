            html.Span(f"📊 Showing {len(filtered_df)} events", style={"fontWeight": "600", "color": "#2d3748"}),
            html.Span(" • ", style={"color": "#cbd5e0"}),
            html.Span(f"Machine: {machine_filter}", style={"color": "#4299e1", "fontWeight": "500"})
        ], style={"marginBottom": "16px", "fontSize": "13px"})
        
        return html.Div([summary, table])
        
    except Exception as e:
        logger.error(f"Error rendering events table: {e}")
        import traceback
        traceback.print_exc()
        return html.Div(f"Error loading data: {str(e)}", style={"color": "#e53e3e", "textAlign": "center", "padding": "40px"})


# =============================================================================
# Load Meters Lost Data (for PGI Lost Bobbin calculation)
# =============================================================================
def load_meters_lost_data(target_dates: list, shift_hours: list) -> dict:
    """
    Loads "Current Shift Meters Lost due to Downtime" from Bobbin_Counts dataset.
    Used to calculate Lost Bobbin = Meters Lost / 128
    
    Returns: Dict mapping hour string to meters lost value
    """
    meters_lost = {hour: 0 for hour in shift_hours}
    
    # Determine which date each hour belongs to (for Shift B midnight crossing)
    hour_to_date = {}
    first_date = target_dates[0]
    second_date = target_dates[1] if len(target_dates) > 1 else first_date
    
    # Detect if this is Shift B (starts at 18:00)
    is_shift_b = shift_hours[0] == "18:00" if shift_hours else False
    
    for hour in shift_hours:
        hour_num = int(hour.split(":")[0])
        if is_shift_b:
            # Shift B: Hours 00:00-06:00 belong to the next day
            if hour_num <= 6:
                hour_to_date[hour] = second_date
            else:
                hour_to_date[hour] = first_date
        else:
            # Shift A: All hours belong to first_date
            hour_to_date[hour] = first_date
    
    try:
        counts_df = dataiku.Dataset("Bobbin_Counts").get_dataframe()
        
        if counts_df.empty:
            return meters_lost
        
        # Filter for the specific tag
        counts_df["Date"] = pd.to_datetime(counts_df["Date"]).dt.date
        counts_df = counts_df[counts_df["Date"].isin(target_dates)]
        counts_df = counts_df[counts_df["Tag"] == "Current Shift Meters Lost due to Downtime"]
        
        if counts_df.empty:
            return meters_lost
        
        # Map values to hours
        for _, row in counts_df.iterrows():
            time_str = str(row.get("Time", "")).strip()
            row_date = row.get("Date")
            if time_str and ":" in time_str:
                hour_part = time_str.split(":")[0].zfill(2)
                hour_key = f"{hour_part}:00"
                
                if hour_key in meters_lost:
                    expected_date = hour_to_date.get(hour_key)
                    if row_date == expected_date:
                        value = row.get("Value", 0)
                        meters_lost[hour_key] = float(value) if pd.notna(value) else 0
        
        logger.info(f"Loaded Meters Lost data: {sum(meters_lost.values()):.2f} total meters")
        
    except Exception as e:
        logger.warning(f"Error loading meters lost data: {e}")
    
    return meters_lost


# =============================================================================
# Load Bobbin Counts Data
# =============================================================================
def load_bobbin_counts(target_dates: list, shift_hours: list, machine: str = "PGI") -> dict:
    """
    Loads production counts from machine-specific dataset for specified dates.
    
    For Shift B (18:00-06:00), this handles midnight crossing by loading data
    from two dates:
    - Hours 18:00-23:00 come from the first date
    - Hours 00:00-05:00 come from the second date (next day)
    
    For PGI (Bobbin_Counts dataset):
    - Data is already hourly (each row = production for that hour)
    - Date: The date of the record
    - Hour: Hour number (integer)
    - Time: Time string (e.g., "09:00")
    - Machine: Machine identifier
    - Tag: Metric type (we filter for "Current Shift # Bobbins")
    - Value: The metric value (bobbin count)
    
    For TL4 (TL4_Tread_Count dataset):
    - Data is CUMULATIVE (each row = running total up to that hour)
    - Need to calculate difference between consecutive hours
    - Date: The date of the record
    - Hour: Hour number (integer)
    - Time: Time string (e.g., "09:00")
    - Tread_Count_Good: Direct count value (no Tag filtering needed)
    
    Args:
        target_dates: List of dates to load data for (1 for Shift A, 2 for Shift B)
        shift_hours: List of hour strings (e.g., ["06:00", "07:00", ...])
        machine: Machine identifier ("PGI", "TL4", etc.)
    
    Returns: Dict mapping hour string to production count (e.g., {"07:00": 24.0})
    """
    # Initialize all hours to 0 (default if no data)
    production_data = {hour: 0 for hour in shift_hours}
    
    # Get machine-specific configuration
    machine_config = Config.get_dataset_config(machine)
    counts_dataset = machine_config["counts"]
    value_col = machine_config["counts_value_col"]
    filter_tag = machine_config["counts_filter_tag"]
    is_cumulative = machine_config.get("counts_is_cumulative", False)  # TL4 is cumulative
    
    # Determine which date each hour belongs to (for Shift B midnight crossing)
    # For Shift A: All hours (06:00-18:00) belong to first_date
    # For Shift B: Hours 18:00-23:00 belong to first_date, hours 00:00-06:00 belong to second_date
    hour_to_date = {}
    first_date = target_dates[0]
    second_date = target_dates[1] if len(target_dates) > 1 else first_date
    
    # Detect if this is Shift B (starts at 18:00)
    is_shift_b = shift_hours[0] == "18:00" if shift_hours else False
    
    for hour in shift_hours:
        hour_num = int(hour.split(":")[0])
        if is_shift_b:
            # Shift B: Hours 00:00-06:00 belong to the next day
            if hour_num <= 6:
                hour_to_date[hour] = second_date
            else:
                hour_to_date[hour] = first_date
        else:
            # Shift A: All hours belong to first_date
            hour_to_date[hour] = first_date
    
    try:
        # Load counts from machine-specific Dataiku dataset
        # OPTIMIZATION: skip_additional_data_checks=True for faster reading
        logger.info(f"Loading counts from {counts_dataset} for {machine}, dates: {target_dates}")
        counts_df = dataiku.Dataset(counts_dataset).get_dataframe(skip_additional_data_checks=True)
        
        if counts_df.empty:
            logger.warning(f"{counts_dataset} dataset is empty")
            return production_data
        
        # =====================================================================
        # Filter data by dates (and optionally by Tag for PGI)
        # =====================================================================
        counts_df["Date"] = pd.to_datetime(counts_df["Date"]).dt.date
        
        # Apply date filter - include all specified dates
        counts_df = counts_df[counts_df["Date"].isin(target_dates)]
        
        # Apply tag filter if needed (PGI uses Tag column, TL4 does not)
        if filter_tag and "Tag" in counts_df.columns:
            counts_df = counts_df[counts_df["Tag"] == filter_tag]
        
        if counts_df.empty:
            logger.info(f"No count data found for {machine} on dates {target_dates}")
            return production_data
        
        # =====================================================================
        # Map each row's Time column to the corresponding hour key
        # First, collect raw values (cumulative for TL4, hourly for PGI)
        # For Shift B: match row's Date to the expected date for that hour
        # =====================================================================
        raw_values = {}  # hour_key -> raw value
        for _, row in counts_df.iterrows():
            time_str = str(row.get("Time", "")).strip()
            row_date = row.get("Date")
            if time_str and ":" in time_str:
                # Normalize time string to "HH:00" format
                hour_part = time_str.split(":")[0].zfill(2)
                hour_key = f"{hour_part}:00"
                
                # Only process if this hour is in our shift AND date matches expected
                if hour_key in production_data:
                    expected_date = hour_to_date.get(hour_key)
                    if row_date == expected_date:
                        value = row.get(value_col, 0) if value_col in row else row.get("Value", 0)
                        raw_values[hour_key] = float(value) if pd.notna(value) else 0
        
        # =====================================================================
        # For cumulative data: Convert cumulative values to hourly production
        # Production for hour N = Cumulative[N] - Cumulative[N-1]
        # First hour shows its actual value (no previous hour to subtract)
        # =====================================================================
        if is_cumulative and raw_values:
            prev_value = None
            for hour in shift_hours:
                if hour in raw_values:
                    current_value = raw_values[hour]
                    if prev_value is not None:
                        # Calculate hourly production as difference from previous hour
                        hourly_production = max(0, current_value - prev_value)
                        production_data[hour] = hourly_production
                    else:
                        # First hour with data - show actual cumulative value as production
                        # (This IS the production for the first hour of the shift)
                        production_data[hour] = current_value
                    prev_value = current_value
                else:
                    # No data for this hour - keep previous value for next calculation
                    pass
        else:
            # PGI: Data is already hourly, use raw values directly
            production_data.update(raw_values)
        
        total = sum(production_data.values())
        logger.info(f"Loaded counts for {machine} on {target_dates}: {total} total (cumulative={is_cumulative})")
        
    except Exception as e:
        logger.warning(f"Error loading counts for {machine}: {e}")
    
    return production_data


# =============================================================================
# HRxHR Data Persistence Functions
# =============================================================================
# Cache for HRxHR data (same pattern as other caches)
_hrxhr_cache = {}

def load_hrxhr_data(machine: str, shift_date: str, shift_hours: list) -> dict:
    """
    Loads persisted HRxHR data from HRxHR_Data dataset.
    
    Args:
        machine: Machine identifier (PGI, TL3, TL4, TL5)
        shift_date: Date string in YYYY-MM-DD format
        shift_hours: List of hour strings like ["06:00", "07:00", ...]
    
    Returns: Dict mapping hour to saved data:
        {
            "06:00": {"primary_count": 0, "secondary_count": 0, "causes": "", "actions": "", "resolved": False},
            ...
        }
    """
    global _hrxhr_cache
    
    # Initialize default empty data for all hours
    result = {hour: {
        "primary_count": None,
        "secondary_count": None,
        "causes": "",
        "actions": "",
        "resolved": False,
        "downtime_minutes": 0,
        "custom_value": None,  # Numeric value for custom column (TL3/TL4/TL5)
        "custom_col_name": ""  # User-defined column name (TL3/TL4/TL5)
    } for hour in shift_hours}
    
    # Check cache
    cache_key = f"hrxhr_{machine}_{shift_date}_{get_cache_key()}"
    if cache_key in _hrxhr_cache:
        logger.info(f"HRxHR cache hit for {machine} {shift_date}")
        return _hrxhr_cache[cache_key]
    
    try:
        # Get dataset name from config
        machine_config = Config.get_dataset_config(machine)
        hrxhr_dataset = machine_config.get("hrxhr", "HRxHR_Data")
        
        dataset = dataiku.Dataset(hrxhr_dataset)
        # OPTIMIZATION: skip_additional_data_checks=True for faster reading
        df = dataset.get_dataframe(skip_additional_data_checks=True)
        
        if df.empty:
            logger.info(f"HRxHR dataset {hrxhr_dataset} is empty")
            _hrxhr_cache[cache_key] = result
            return result
        
        # Filter for this machine and date
        # Ensure column types
        if "Machine" in df.columns:
            df = df[df["Machine"] == machine]
        if "Shift_Date" in df.columns:
            df["Shift_Date"] = df["Shift_Date"].astype(str)
            df = df[df["Shift_Date"].str.startswith(shift_date)]
        
        if df.empty:
            logger.info(f"No HRxHR data found for {machine} on {shift_date}")
            _hrxhr_cache[cache_key] = result
            return result
        
        # Map data to hours
        for _, row in df.iterrows():
            hour_val = row.get("Hour")
            if hour_val is None:
                continue
            
            # Convert hour to string format "HH:00"
            try:
                hour_int = int(hour_val)
                hour_str = f"{hour_int:02d}:00"
            except (ValueError, TypeError):
                continue
            
            if hour_str in result:
                result[hour_str] = {
                    "primary_count": row.get("Primary_Count") if pd.notna(row.get("Primary_Count")) else None,
                    "secondary_count": row.get("Secondary_Count") if pd.notna(row.get("Secondary_Count")) else None,
                    "causes": str(row.get("Causes", "")) if pd.notna(row.get("Causes")) else "",
                    "actions": str(row.get("Actions", "")) if pd.notna(row.get("Actions")) else "",
                    "resolved": bool(row.get("Resolved", False)) if pd.notna(row.get("Resolved")) else False,
                    "downtime_minutes": float(row.get("Downtime_Minutes", 0)) if pd.notna(row.get("Downtime_Minutes")) else 0,
                    "custom_value": row.get("Custom_Value") if pd.notna(row.get("Custom_Value")) else None,
                    "custom_col_name": str(row.get("Custom_Column_Name", "")) if pd.notna(row.get("Custom_Column_Name")) else ""
                }
        
        logger.info(f"Loaded HRxHR data for {machine} {shift_date}: {len([h for h in result if result[h]['causes'] or result[h]['actions']])} hours with data")
        _hrxhr_cache[cache_key] = result
        return result
        
    except Exception as e:
        logger.warning(f"Error loading HRxHR data for {machine} {shift_date}: {e}")
        return result


def save_hrxhr_data(machine: str, shift_date: str, hourly_data: dict) -> str:
    """
    Saves HRxHR data to HRxHR_Data dataset.
    Performs upsert: updates existing rows or inserts new ones.
    
    Args:
        machine: Machine identifier
        shift_date: Date string in YYYY-MM-DD format
        hourly_data: Dict mapping hour string to data dict
            {"06:00": {"primary_count": 5, "secondary_count": 2, "causes": "...", "actions": "...", "resolved": True, "downtime_minutes": 15}}
    
    Returns: Success or error message
    """
    global _hrxhr_cache
    
    try:
        machine_config = Config.get_dataset_config(machine)
        hrxhr_dataset = machine_config.get("hrxhr", "HRxHR_Data")
        
        dataset = dataiku.Dataset(hrxhr_dataset)
        
        # Load existing data
        try:
            existing_df = dataset.get_dataframe()
        except Exception:
            existing_df = pd.DataFrame()
        
        # Prepare new/updated rows
        now = datetime.datetime.now().strftime("%Y-%m-%d %H:%M:%S")
        new_rows = []
        
        for hour_str, data in hourly_data.items():
            # Extract hour integer from "HH:00" format
            try:
                hour_int = int(hour_str.split(":")[0])
            except (ValueError, IndexError):
                continue
            
            row = {
                "Machine": machine,
                "Shift_Date": shift_date,
                "Hour": hour_int,
                "Primary_Count": data.get("primary_count"),
                "Secondary_Count": data.get("secondary_count"),
                "Downtime_Minutes": data.get("downtime_minutes", 0),
                "Causes": data.get("causes", ""),
                "Actions": data.get("actions", ""),
                "Resolved": data.get("resolved", False),
                "Custom_Value": data.get("custom_value"),  # Numeric value for TL3/TL4/TL5 custom column
                "Custom_Column_Name": data.get("custom_col_name", ""),  # User-defined column name
                "Last_Updated": now
            }
            new_rows.append(row)
        
        if not new_rows:
            return "⚠️ No data to save"
        
        new_df = pd.DataFrame(new_rows)
        
        # Merge with existing (upsert pattern)
        if not existing_df.empty and "Shift_Date" in existing_df.columns and "Machine" in existing_df.columns:
            # Remove existing rows for this machine+date (we'll replace them)
            existing_df["Shift_Date"] = existing_df["Shift_Date"].astype(str)
            keep_mask = ~((existing_df["Machine"] == machine) & (existing_df["Shift_Date"].str.startswith(shift_date)))
            existing_df = existing_df[keep_mask]
            
            # Combine old + new
            final_df = pd.concat([existing_df, new_df], ignore_index=True)
        else:
            # Dataset is empty or doesn't have expected columns - just use new data
            final_df = new_df
        
        # Write back to dataset
        dataset.write_with_schema(final_df)
        
        # Invalidate cache for this machine
        keys_to_remove = [k for k in _hrxhr_cache if k.startswith(f"hrxhr_{machine}")]
        for k in keys_to_remove:
            del _hrxhr_cache[k]
        
        logger.info(f"Saved HRxHR data for {machine} {shift_date}: {len(new_rows)} hours")
        return f"✅ Saved {len(new_rows)} hours for {machine}"
        
    except Exception as e:
        logger.error(f"Error saving HRxHR data: {e}")
        import traceback
        traceback.print_exc()
        return f"❌ Error saving: {str(e)}"


# =============================================================================
# HRxHR Table Rendering Function
# =============================================================================
def render_hrxhr_table(df: pd.DataFrame, duration_threshold: int, start_dt: pd.Timestamp, end_dt: pd.Timestamp, machine: str = "PGI") -> html.Div:
    """
    Renders the HRxHR (Hour by Hour) view with production bar chart and hourly table.
    
    This view shows:
    1. Bar chart - Production per hour (from machine-specific counts dataset)
    2. Table - One row per hour showing downtime, causes, actions, status
    
    KEY FEATURE - Auto-population from Event Categorization:
    - CAUSES column: Auto-populated from Reasons (category codes A1, F13, etc.)
      → Codes are converted to full labels (e.g., "F13 Machine breakdown")
    - ACTIONS column: Auto-populated from Comments entered in Event Categorization
    This creates a direct link between categorization and HRxHR tracking.
    
    Key Features:
    - Shift A: 06:00-18:00 (12 hours)
    - Shift B: 18:00-06:00 (12 hours, crosses midnight)
    - First hour shows actual production (cumulative value for that hour)
    - Downtime spillover: Events spanning multiple hours are distributed
      (e.g., 50 min event starting at 11:49 = 11 min in 11:00 hour + 39 min in 12:00 hour)
    - Color coding by downtime percentage:
      * Green: <5% downtime
      * Light Green: 5-25%
      * Yellow: 25-50%
      * Red: ≥50%
    
    Args:
        df: DataFrame with event data
        duration_threshold: Minimum duration filter
        start_dt: Shift start datetime
        end_dt: Shift end datetime
        machine: Machine identifier for loading counts from correct dataset
    
    Returns: html.Div containing the complete HRxHR view
    """
    try:
        # =====================================================================
        # STEP 1: Apply filters to event data
        # =====================================================================
        # Machine filter (ensure we only process events for selected machine)
        if "Machine" in df.columns:
            df = df[df["Machine"] == machine]
        
        # HRxHR view should only count DOWNTIME events, not SLOWTIME
        # SLOWTIME = speed loss (machine running slow), not actual downtime
        if Config.EVENT_COL in df.columns:
            df = df[df[Config.EVENT_COL].str.upper() == "DOWNTIME"]
        
        if Config.DURATION_COL in df.columns:
            duration_numeric = pd.to_numeric(df[Config.DURATION_COL], errors='coerce')
            # Include ongoing events (EndTime starts with "9999") regardless of duration
            is_ongoing = df[Config.END_TIME_COL].astype(str).str.startswith("9999")
            df = df[(duration_numeric > duration_threshold) | is_ongoing]

        if Config.START_TIME_COL in df.columns:
            df[Config.START_TIME_COL] = pd.to_datetime(df[Config.START_TIME_COL], errors='coerce')
            df = df[(df[Config.START_TIME_COL] >= start_dt) & (df[Config.START_TIME_COL] < end_dt)]
        
        # =====================================================================
        # STEP 2: Determine shift hours based on start time
        # Include the END hour to capture the last hour's production
        # (e.g., 18:00 shows production from 17:00-18:00 via cumulative diff)
        # =====================================================================
        shift_start_hour = start_dt.hour if start_dt else 6
        if shift_start_hour == 6:
            # Shift A: Generate hours 06:00 through 18:00 (includes end hour)
            # 18:00 shows production from 17:00-18:00
            shift_hours = [f"{h:02d}:00" for h in range(6, 19)]
            shift_label = "Shift A (06:00 - 18:00)"
        else:
            # Shift B: Generate hours 18:00-23:00, then 00:00-06:00 (includes end hour)
            # 06:00 shows production from 05:00-06:00
            shift_hours = [f"{h:02d}:00" for h in range(18, 24)] + [f"{h:02d}:00" for h in range(0, 7)]
            shift_label = "Shift B (18:00 - 06:00)"
        
        # =====================================================================
        # STEP 3: Load production counts from machine-specific dataset
        # For Shift B (crosses midnight), we need data from TWO dates:
        #   - Hours 18:00-23:00 come from start_dt's date
        #   - Hours 00:00-05:00 come from the next day
        # =====================================================================
        start_date = start_dt.date() if start_dt else datetime.date.today()
        
        # Determine if this is Shift B (starts at 18:00, crosses midnight)
        if shift_start_hour == 18:
            # Shift B: need both dates
            next_date = start_date + datetime.timedelta(days=1)
            target_dates = [start_date, next_date]
        else:
            # Shift A: single date
            target_dates = [start_date]
        
        bobbin_counts = load_bobbin_counts(target_dates, shift_hours, machine)
        
        # Load meters lost data for PGI (used to calculate Lost Bobbin)
        meters_lost_data = {}
        if machine == "PGI":
            meters_lost_data = load_meters_lost_data(target_dates, shift_hours)
        
        # NOTE: First hour now shows actual production (cumulative value for that hour)
        # Previously forced to 0, now correctly displays production
        
        # =====================================================================
        # STEP 3.5: Load saved HRxHR data from dataset
        # This retrieves any previously saved user inputs (causes, actions, etc.)
        # =====================================================================
        shift_date_str = start_date.strftime("%Y-%m-%d") if hasattr(start_date, 'strftime') else str(start_date)
        saved_hrxhr = load_hrxhr_data(machine, shift_date_str, shift_hours)
        
        # =====================================================================
        # STEP 4: Initialize hourly data structure
        # =====================================================================
        hourly_data = {hour: {
            "events": [],              # List of events in this hour
            "intervals": [],           # List of (start_min, end_min) tuples for overlap merging
            "downtime_minutes": 0,     # Total downtime minutes (calculated after merge)
            "count": 0,                # Number of events starting in this hour
            "descriptions": [],        # Spillover descriptions
            "comments": [],            # User comments from events
            "reasons": [],             # Category reasons from events
            "bobbins": bobbin_counts.get(hour, 0),  # Bobbin count from Bobbin_Counts
            "meters_lost": meters_lost_data.get(hour, 0),  # Meters lost (PGI only)
        } for hour in shift_hours}
        
        # =====================================================================
        # STEP 5: Collect time intervals for each hour
        # Instead of accumulating minutes directly, we collect intervals
        # so we can merge overlaps later for accurate calculation.
        # 
        # Example: Event starts at 7:15 with 60 min duration:
        #   - 7:00 hour gets interval (15, 60) meaning minutes 15-60 of that hour
        #   - 8:00 hour gets interval (0, 15) meaning minutes 0-15 of that hour
        # =====================================================================
        if not df.empty and Config.START_TIME_COL in df.columns:
            for idx, row in df.iterrows():
                event_dt = row[Config.START_TIME_COL]
                if pd.isna(event_dt):
                    continue
                
                # Get event duration in minutes
                # For ongoing events (end time = 9999-*), calculate duration from start to now
                end_time_str = str(row.get(Config.END_TIME_COL, ""))
                is_event_ongoing = end_time_str.startswith("9999")
                
                if is_event_ongoing:
                    # Ongoing event: calculate duration from start to current time
                    now = datetime.datetime.now()
                    duration = (now - event_dt).total_seconds() / 60
                else:
                    duration = float(row[Config.DURATION_COL]) if Config.DURATION_COL in row and not pd.isna(row[Config.DURATION_COL]) else 0
                
                if duration <= 0:
                    continue
                
                # Calculate event time window
                event_start = event_dt
                if is_event_ongoing:
                    # For ongoing events, end at current time
                    event_end = datetime.datetime.now()
                else:
                    event_end = event_dt + datetime.timedelta(minutes=duration)
                
                # Walk through each hour the event touches
                current_time = event_start
                while current_time < event_end:
                    hour_str = f"{current_time.hour:02d}:00"
                    
                    if hour_str in hourly_data:
                        # Calculate hour block boundaries
                        hour_start = current_time.replace(minute=0, second=0, microsecond=0)
                        hour_end = hour_start + datetime.timedelta(hours=1)
                        
                        # Calculate interval within this hour (0-60 minutes)
                        # interval_start: minute of hour when downtime starts
                        # interval_end: minute of hour when downtime ends
                        interval_start = max(0, (current_time - hour_start).total_seconds() / 60)
                        interval_end = min(60, (min(event_end, hour_end) - hour_start).total_seconds() / 60)
                        
                        # Store interval for later merge
                        hourly_data[hour_str]["intervals"].append((interval_start, interval_end))
                        
                        # Only count event once (in its starting hour)
                        hourly_data[hour_str]["count"] += 1 if current_time == event_start else 0
                        
                        # For the starting hour, capture event with its reasons and comment together
                        if current_time == event_start:
                            event_info = {"reasons": [], "comment": ""}
                            
                            comment = row.get(Config.COMMENT_COL, "")
                            if comment and str(comment).strip() and str(comment).lower() != "nan":
                                event_info["comment"] = str(comment).strip()
                            
                            # Reasons may be comma-separated (e.g., "A2,E31,G3") - split and store
                            reasons = row.get(Config.REASONS_COL, "")
                            if reasons and str(reasons).strip() and str(reasons).lower() != "nan":
                                for reason_code in str(reasons).split(","):
                                    reason_code = reason_code.strip()
                                    if reason_code:
                                        event_info["reasons"].append(reason_code)
                            
                            # Only add event if it has reasons or comment
                            if event_info["reasons"] or event_info["comment"]:
                                hourly_data[hour_str]["events"].append(event_info)
                        else:
                            # For spillover hours, add a note showing where event originated
                            mins_in_hour = int(interval_end - interval_start)
                            spillover_note = f"↳ Continues from {event_start.strftime('%H:%M')} ({mins_in_hour} min)"
                            if spillover_note not in hourly_data[hour_str]["descriptions"]:
                                hourly_data[hour_str]["descriptions"].append(spillover_note)
                        
                        # Move to next hour
                        current_time = hour_end
                    else:
                        # Skip hours not in our shift
                        current_time = current_time.replace(minute=0, second=0, microsecond=0) + datetime.timedelta(hours=1)
        
        # =====================================================================
        # STEP 5.5: Merge overlapping intervals and calculate actual downtime
        # This handles overlapping events correctly:
        # Example: Event1 (10,40) + Event2 (30,55) → merged (10,55) = 45 min
        # Without merge: 30 + 25 = 55 min (wrong - counts overlap twice)
        # =====================================================================
        def merge_intervals(intervals):
            """Merge overlapping time intervals and return total minutes."""
            if not intervals:
                return 0
            
            # Sort intervals by start time
            sorted_intervals = sorted(intervals, key=lambda x: x[0])
            merged = [sorted_intervals[0]]
            
            for current_start, current_end in sorted_intervals[1:]:
                last_start, last_end = merged[-1]
                
                if current_start <= last_end:
                    # Overlapping - extend the last interval
                    merged[-1] = (last_start, max(last_end, current_end))
                else:
                    # No overlap - add new interval
                    merged.append((current_start, current_end))
            
            # Calculate total minutes from merged intervals
            total = sum(end - start for start, end in merged)
            return min(60, total)  # Safety cap at 60 (should never exceed after merge)
        
        # Apply merge to each hour
        for hour in hourly_data:
            hourly_data[hour]["downtime_minutes"] = merge_intervals(hourly_data[hour]["intervals"])
        
