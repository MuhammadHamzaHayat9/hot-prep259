# Cached data storage - now machine-specific
_data_cache = {}

def load_events_data(machine: str = "PGI") -> pd.DataFrame:
    """
    Loads the Events_Stacked dataset and merges with any saved annotations.
    Uses simple in-memory caching with time-based invalidation.
    
    Data Flow:
    1. Check cache - return cached data if still valid
    2. Load raw events from Events_Stacked dataset
    3. Ensure column types are correct
    4. Add empty annotation columns if missing
    5. Extract machine name from Composite_Key
    6. Merge with saved annotations from TRSP_APP_DATA
    7. Auto-assign G1 category to uncategorized SLOWTIME events
    8. Cache and return
    
    Returns: DataFrame ready for display
    """
    global _data_cache
    
    # Get machine-specific dataset configuration
    machine_config = Config.get_dataset_config(machine)
    events_dataset = machine_config["events"]
    annotations_dataset = machine_config["annotations"]
    product_col = machine_config["product_col"]
    has_width = machine_config["has_width"]
    
    # Check cache validity - now machine-specific
    cache_key = f"{machine}_{get_cache_key()}"
    if machine in _data_cache and _data_cache[machine].get("key") == cache_key and _data_cache[machine].get("data") is not None:
        logger.info(f"Returning cached data for {machine}")
        return _data_cache[machine]["data"].copy()  # Return copy to prevent mutation
    
    try:
        logger.info(f"Cache miss - loading fresh data for {machine}")
        # =====================================================================
        # STEP 1: Load source data from Dataiku dataset
        # OPTIMIZATION: skip_additional_data_checks=True for faster reading
        # =====================================================================
        logger.info(f"Loading dataset: {events_dataset}")
        source_df = dataiku.Dataset(events_dataset).get_dataframe(skip_additional_data_checks=True)
        logger.info(f"Loaded {len(source_df)} records from source")
        
        # =====================================================================
        # STEP 1.5: Normalize column names for TL4 compatibility
        # TL4 uses "Product" instead of "Recipe", and has no "Product_Width"
        # =====================================================================
        if product_col != Config.RECIPE_COL and product_col in source_df.columns:
            # Create Recipe column from Product for unified handling
            source_df[Config.RECIPE_COL] = source_df[product_col]
        
        if not has_width and Config.WIDTH_COL not in source_df.columns:
            # Add empty Product_Width column for unified handling
            source_df[Config.WIDTH_COL] = ""
        
        # Add Machine column based on selected machine (for TL4 it's not in Composite_Key)
        source_df["Machine"] = machine
        
        # Normalize Event column to uppercase (Quad_Prep uses "Downtime" instead of "DOWNTIME")
        if Config.EVENT_COL in source_df.columns:
            source_df[Config.EVENT_COL] = source_df[Config.EVENT_COL].astype(str).str.upper()
        
        # =====================================================================
        # STEP 2: Ensure column types are correct
        # =====================================================================
        # Composite_Key must be string for lookups
        source_df[Config.UNIQUE_KEY] = source_df[Config.UNIQUE_KEY].astype(str)
        
        # Duration must be numeric (integer minutes)
        if Config.DURATION_COL in source_df.columns:
            source_df[Config.DURATION_COL] = pd.to_numeric(source_df[Config.DURATION_COL], errors='coerce').fillna(0).astype('int64')
        
        # =====================================================================
        # STEP 3: Add annotation columns if not present in source
        # =====================================================================
        # These columns store user input: Reasons, Comment, ReasonDurations
        for col in [Config.REASONS_COL, Config.COMMENT_COL, Config.REASON_DURATIONS_COL]:
            if col not in source_df.columns:
                source_df[col] = ""
            else:
                source_df[col] = source_df[col].fillna("").astype(str)
        
        # =====================================================================
        # STEP 4: Machine column already set above for unified handling
        # For PGI, we could extract from Composite_Key, but we use the selected machine
        # This ensures consistency when filtering by machine
        # =====================================================================
        # Machine column already set above: source_df["Machine"] = machine
        
        # =====================================================================
        # STEP 5: Try to load and merge saved annotations from machine-specific dataset
        # Uses efficient pandas merge instead of row-by-row iteration
        # OPTIMIZATION: skip_additional_data_checks=True for faster reading
        # =====================================================================
        try:
            annotations_df = dataiku.Dataset(annotations_dataset).get_dataframe(skip_additional_data_checks=True)
            if not annotations_df.empty:
                annotations_df[Config.UNIQUE_KEY] = annotations_df[Config.UNIQUE_KEY].astype(str)
                
                # Select only the columns we need from annotations
                ann_cols = [Config.UNIQUE_KEY, Config.REASONS_COL, Config.COMMENT_COL, Config.REASON_DURATIONS_COL]
                ann_cols = [c for c in ann_cols if c in annotations_df.columns]
                annotations_subset = annotations_df[ann_cols].copy()
                
                # Rename columns to avoid conflicts during merge
                annotations_subset = annotations_subset.rename(columns={
                    Config.REASONS_COL: f"{Config.REASONS_COL}_saved",
                    Config.COMMENT_COL: f"{Config.COMMENT_COL}_saved",
                    Config.REASON_DURATIONS_COL: f"{Config.REASON_DURATIONS_COL}_saved"
                })
                
                # Merge annotations with source data
                source_df = source_df.merge(annotations_subset, on=Config.UNIQUE_KEY, how='left')
                
                # Update annotation columns with saved values where they exist
                for col in [Config.REASONS_COL, Config.COMMENT_COL, Config.REASON_DURATIONS_COL]:
                    saved_col = f"{col}_saved"
                    if saved_col in source_df.columns:
                        source_df[col] = source_df[saved_col].fillna(source_df[col])
                        source_df = source_df.drop(columns=[saved_col])
                
                logger.info(f"Merged {len(annotations_df)} saved annotations")
        except Exception as e:
            logger.warning(f"Could not load annotations dataset: {e}")
        
        # =====================================================================
        # STEP 6: Auto-assign G1 to SLOWTIME events without categories
        # Uses vectorized operations for speed instead of row-by-row iteration
        # =====================================================================
        # Business rule: SLOWTIME events default to G1 (Production in Slowed Operation)
        
        # Helper function to check if a row has categories
        def has_valid_categories(reason_durations):
            try:
                if reason_durations and str(reason_durations) not in ["", "nan", "None"]:
                    parsed = json.loads(str(reason_durations))
                    return len(parsed) > 0
            except (json.JSONDecodeError, TypeError, ValueError):
                pass
            return False
        
        # Helper function to create G1 allocation JSON
        def create_g1_allocation(duration):
            if duration and duration > 0:
                return json.dumps([{"reason": "G1", "duration": int(duration)}])
            return ""
        
        # Find SLOWTIME events without categories
        is_slowtime = source_df[Config.EVENT_COL].astype(str).str.upper() == "SLOWTIME"
        has_cats = source_df[Config.REASON_DURATIONS_COL].apply(has_valid_categories)
        needs_g1 = is_slowtime & ~has_cats & (source_df[Config.DURATION_COL] > 0)
        
        # Apply G1 to qualifying rows
        if needs_g1.any():
            source_df.loc[needs_g1, Config.REASON_DURATIONS_COL] = source_df.loc[needs_g1, Config.DURATION_COL].apply(create_g1_allocation)
            source_df.loc[needs_g1, Config.REASONS_COL] = "G1"
            logger.info(f"Auto-assigned G1 to {needs_g1.sum()} SLOWTIME events")
        
        # Store in cache before returning - machine-specific
        if machine not in _data_cache:
            _data_cache[machine] = {}
        _data_cache[machine]["key"] = cache_key
        _data_cache[machine]["data"] = source_df.copy()
        _data_cache[machine]["timestamp"] = datetime.datetime.now()
        logger.info(f"Cached {len(source_df)} rows for {machine} at {_data_cache[machine]['timestamp']}")
        
        return source_df
        
    except Exception as e:
        logger.error(f"Error loading events data: {e}")
        return pd.DataFrame()


def invalidate_cache(machine: str = None):
    """Invalidate the data cache after save operations.
    If machine is specified, only invalidate that machine's cache.
    Otherwise, invalidate all caches.
    """
    global _data_cache
    if machine:
        if machine in _data_cache:
            _data_cache[machine] = {}
            logger.info(f"Cache invalidated for {machine}")
    else:
        _data_cache = {}
        logger.info("All caches invalidated")


def save_annotations(annotations_data: list, machine: str = "PGI") -> str:
    """
    Saves user annotations to the machine-specific dataset.
    This performs an upsert: updates existing records or inserts new ones.
    
    Args:
        annotations_data: List of dicts with keys:
            - Composite_Key: Unique event identifier
            - Reasons: Comma-separated category codes (e.g., "F13A,E1")
            - ReasonDurations: JSON array of allocations (e.g., [{"reason":"F13A","duration":30}])
            - Comment: User comment text
        machine: Machine identifier ("PGI", "TL4", etc.)
    
    Returns: Success or error message string
    """
    try:
        if not annotations_data:
            return "No changes to save"
        
        # Get machine-specific dataset configuration
        machine_config = Config.get_dataset_config(machine)
        events_dataset = machine_config["events"]
        annotations_dataset = machine_config["annotations"]
        
        logger.info(f"Saving annotations for {machine} to {annotations_dataset}")
        
        # =====================================================================
        # STEP 1: Load existing data from machine-specific annotations dataset
        # OPTIMIZATION: skip_additional_data_checks=True for faster reading
        # =====================================================================
        try:
            current_df = dataiku.Dataset(annotations_dataset).get_dataframe(skip_additional_data_checks=True)
            current_df[Config.UNIQUE_KEY] = current_df[Config.UNIQUE_KEY].astype(str)
        except Exception:
            # If dataset doesn't exist or is empty, start fresh
            current_df = pd.DataFrame()
        
        # =====================================================================
        # STEP 2: Load source events from machine-specific events dataset (for new rows)
        # OPTIMIZATION: skip_additional_data_checks=True + vectorized to_dict('index')
        # =====================================================================
        try:
            source_df = dataiku.Dataset(events_dataset).get_dataframe(skip_additional_data_checks=True)
            source_df[Config.UNIQUE_KEY] = source_df[Config.UNIQUE_KEY].astype(str)
            # OPTIMIZATION: Use vectorized to_dict('index') instead of iterrows() - ~100x faster
            source_map = source_df.set_index(Config.UNIQUE_KEY).to_dict('index')
        except Exception:
            source_map = {}
        
        # =====================================================================
        # STEP 3: Build lookup map from existing TRSP_APP_DATA
        # OPTIMIZATION: Use vectorized to_dict('index') instead of iterrows()
        # =====================================================================
        current_map = {}
        if not current_df.empty:
            current_map = current_df.set_index(Config.UNIQUE_KEY).to_dict('index')
        
        # =====================================================================
        # STEP 4: Merge new annotations (upsert logic)
        # =====================================================================
        now_iso = datetime.datetime.now().isoformat()
        
        for ann in annotations_data:
            key = ann[Config.UNIQUE_KEY]
            if key in current_map:
                # Update existing record - keep all columns, update annotations
                current_map[key].update(ann)
                
                # Update enhanced columns
                reason_durations = ann.get(Config.REASON_DURATIONS_COL, "[]")
                calc_duration = current_map[key].get(Config.DURATION_COL) or current_map[key].get(Config.CALCULATED_DURATION_COL)
                end_time = current_map[key].get(Config.END_TIME_COL, "")
                
                current_map[key][Config.CALCULATED_DURATION_COL] = calc_duration
                current_map[key][Config.CATEGORIZATION_STATUS_COL] = calculate_categorization_status(reason_durations, calc_duration, end_time)
                current_map[key][Config.UNALLOCATED_MINUTES_COL] = calculate_unallocated_minutes(reason_durations, calc_duration)
                current_map[key][Config.LAST_SYNCED_COL] = now_iso
            else:
                # NEW record - get full event details from Events_Stacked first
                if key in source_map:
                    # Start with full event data from source
                    new_record = source_map[key].copy()
                    # Add annotation columns
                    new_record.update(ann)
                    
                    # Add enhanced columns for new records
                    reason_durations = ann.get(Config.REASON_DURATIONS_COL, "[]")
                    calc_duration = new_record.get(Config.DURATION_COL, 0)
                    end_time = new_record.get(Config.END_TIME_COL, "")
                    
                    new_record[Config.CALCULATED_DURATION_COL] = calc_duration
                    new_record[Config.CATEGORIZATION_STATUS_COL] = calculate_categorization_status(reason_durations, calc_duration, end_time)
                    new_record[Config.UNALLOCATED_MINUTES_COL] = calculate_unallocated_minutes(reason_durations, calc_duration)
                    new_record[Config.LAST_SYNCED_COL] = now_iso
                    new_record[Config.CATEGORIZED_AT_COL] = now_iso
                    
                    current_map[key] = new_record
                else:
                    # Fallback: just use annotation data (shouldn't happen)
                    current_map[key] = ann
        
        # =====================================================================
        # STEP 5: Convert map back to DataFrame for saving
        # =====================================================================
        save_df = pd.DataFrame(list(current_map.values()))
        
        # =====================================================================
        # STEP 6: Write to Dataiku using write_with_schema
        # This auto-updates the schema to include new columns (Reasons, etc.)
        # =====================================================================
        # Ensure all annotation columns exist and are properly typed
        all_annotation_cols = [
            Config.REASONS_COL, Config.REASON_DURATIONS_COL, Config.COMMENT_COL,
            Config.CALCULATED_DURATION_COL, Config.LAST_SYNCED_COL,
            Config.CATEGORIZATION_STATUS_COL, Config.UNALLOCATED_MINUTES_COL,
            Config.CATEGORIZED_AT_COL
        ]
        for col in all_annotation_cols:
            if col not in save_df.columns:
                save_df[col] = ""
            save_df[col] = save_df[col].fillna("").astype(str)
        
        # Ensure key column is string
        save_df[Config.UNIQUE_KEY] = save_df[Config.UNIQUE_KEY].astype(str)
        
        # Write all columns - write_with_schema auto-updates the dataset schema
        dataset = dataiku.Dataset(annotations_dataset)
        dataset.write_with_schema(save_df)
        
        # Invalidate cache so next load gets fresh data with saved annotations
        invalidate_cache(machine)
        
        logger.info(f"Saved {len(annotations_data)} annotations for {machine}")
        return f"✅ Saved {len(annotations_data)} changes successfully!"
        
    except Exception as e:
        logger.error(f"Error saving annotations: {e}")
        return f"❌ Error saving: {str(e)}"


def generate_duration_filter_options() -> tuple:
    """
    Generates dropdown options for the duration filter.
    OPTIMIZATION: skip_additional_data_checks=True for faster reading
    """
    try:
        df = dataiku.Dataset(Config.ORIGINAL_DATASET).get_dataframe(skip_additional_data_checks=True)
        if Config.DURATION_COL in df.columns:
            df[Config.DURATION_COL] = pd.to_numeric(df[Config.DURATION_COL], errors='coerce').fillna(0)
            dmax = int(df[Config.DURATION_COL].max())
            
            options = [
                {"label": "Duration ≥ 0", "value": 0},
                {"label": "Duration > 5", "value": 5}
            ]
            current = 10
            while current <= dmax:
                options.append({"label": f"Duration > {current}", "value": current})
                current += 50
            
            return options, Config.DEFAULT_DURATION_THRESHOLD
        return [{"label": "Duration ≥ 0", "value": 0}], 0
    except Exception as e:
        logger.warning(f"Error generating duration options: {e}")
        return [{"label": "Duration ≥ 0", "value": 0}], 0


