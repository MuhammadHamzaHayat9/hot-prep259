# =============================================================================
# Add Category Callback
# =============================================================================
# Called when user clicks "+" button to add a reason category to an event
#
# IMPORTANT: This does NOT save to Dataiku immediately!
# Changes are stored in pending-changes (browser session) until user clicks "Update" or "Save All"
#
# Flow:
#   1. User selects category from dropdown (e.g., "A1 - Equipment Malfunction")
#   2. User enters duration OR checks "Use remaining" checkbox
#   3. User clicks "+" button
#   4. This callback validates input and adds to pending changes
#   5. Table re-renders showing the new category (with "unsaved" indicator)
#
# Uses pattern-matching callback with {"type": "add-category", "index": ALL}
# to handle clicks from ANY row's add button
@app.callback(
    Output("pending-changes", "data", allow_duplicate=True),
    Output("refresh-trigger", "children", allow_duplicate=True),
    Output("validation-message", "children", allow_duplicate=True),
    Input({"type": "add-category", "index": ALL}, "n_clicks"),
    State({"type": "add-category", "index": ALL}, "id"),
    State({"type": "category-select", "index": ALL}, "value"),
    State({"type": "duration-input", "index": ALL}, "value"),
    State({"type": "use-remaining", "index": ALL}, "value"),
    State({"type": "allocations-store", "index": ALL}, "data"),
    State("pending-changes", "data"),
    State("session-data", "data"),
    prevent_initial_call=True
)
def add_category(add_clicks, button_ids, categories, durations, use_remaining_list, stores, pending, session_data):
    # Pattern-matching callbacks fire for ALL matching components
    # Check if any button was actually clicked
    if not any(clicks for clicks in add_clicks if clicks):
        raise PreventUpdate
    
    trig = ctx.triggered_id
    if not isinstance(trig, dict) or trig.get("type") != "add-category":
        raise PreventUpdate
    
    row_key = trig.get("index")
    clicked_index = None
    for i, bid in enumerate(button_ids):
        if bid.get("index") == row_key:
            clicked_index = i
            break
    
    if clicked_index is None:
        raise PreventUpdate
    
    category = categories[clicked_index] if clicked_index < len(categories) else None
    duration = durations[clicked_index] if clicked_index < len(durations) else None
    use_remaining = "use_remaining" in (use_remaining_list[clicked_index] if clicked_index < len(use_remaining_list) else [])
    store_data = stores[clicked_index] if clicked_index < len(stores) else "[]"
    
    if not category:
        return no_update, no_update, "❌ Please select a category"
    if not use_remaining and (not duration or duration <= 0):
        return no_update, no_update, "❌ Please enter a valid duration or check 'Use remaining'"
    
    try:
        # Parse session data to get total duration
        df = pd.read_json(session_data, orient='split')
        row_data = df[df[Config.UNIQUE_KEY] == row_key]
        if row_data.empty:
            return no_update, no_update, "❌ Event not found"
        
        total_duration = float(row_data.iloc[0][Config.DURATION_COL]) if Config.DURATION_COL in row_data.columns else 0
        
        # Parse existing allocations
        existing = json.loads(store_data) if store_data and store_data != "[]" else []
        existing_codes = [a.get("reason") for a in existing]
        
        if category in existing_codes:
            return no_update, no_update, f"❌ Category '{category}' already exists"
        
        allocated = sum(float(a.get("duration", 0) or 0) for a in existing)
        remaining = max(0, total_duration - allocated)
        
        if use_remaining:
            if remaining <= 0:
                return no_update, no_update, "❌ No remaining time available"
            final_duration = remaining
        else:
            if duration > remaining:
                return no_update, no_update, f"❌ Duration exceeds remaining time ({int(remaining)} min)"
            final_duration = int(duration)
        
        existing.append({"reason": category, "duration": final_duration})
        
        # Update pending changes
        pending_dict = json.loads(pending) if pending else {}
        pending_dict[row_key] = {
            Config.UNIQUE_KEY: row_key,
            Config.REASON_DURATIONS_COL: json.dumps(existing),
            Config.REASONS_COL: ",".join([a["reason"] for a in existing])
        }
        
        trigger = f"add-{row_key}-{int(datetime.datetime.now().timestamp()*1000)}"
        return json.dumps(pending_dict), trigger, f"✅ '{category}' added with {int(final_duration)} min (unsaved)"
        
    except Exception as e:
        logger.error(f"Error adding category: {e}")
        return no_update, no_update, f"❌ Error: {str(e)}"


# =============================================================================
# Remove Category Callback  
# =============================================================================
# Called when user clicks "×" button to remove a reason category from an event
#
# Like add_category, this stores changes locally until saved.
# The callback ID includes both the row index AND the reason code,
# so we know exactly which category to remove from which event.
#
# Example ID: {"type": "remove-category", "index": "PGI_12345", "reason": "A1"}
@app.callback(
    Output("pending-changes", "data", allow_duplicate=True),
    Output("refresh-trigger", "children", allow_duplicate=True),
    Output("validation-message", "children", allow_duplicate=True),
    Input({"type": "remove-category", "index": ALL, "reason": ALL}, "n_clicks"),
    State({"type": "remove-category", "index": ALL, "reason": ALL}, "id"),
    State({"type": "allocations-store", "index": ALL}, "data"),
    State({"type": "allocations-store", "index": ALL}, "id"),
    State("pending-changes", "data"),
    prevent_initial_call=True
)
def remove_category(remove_clicks, remove_ids, stores_data, stores_ids, pending):
    # Check if any remove button was actually clicked
    if not any(clicks for clicks in remove_clicks if clicks):
        raise PreventUpdate
    
    trig = ctx.triggered_id
    if not isinstance(trig, dict) or trig.get("type") != "remove-category":
        raise PreventUpdate
    
    row_key = trig.get("index")
    category_to_remove = trig.get("reason")
    
    if not row_key or not category_to_remove:
        raise PreventUpdate
    
    try:
        pending_dict = json.loads(pending) if pending else {}
        
        # FIRST check if there are pending changes for this row (e.g., from add)
        if row_key in pending_dict and Config.REASON_DURATIONS_COL in pending_dict[row_key]:
            existing = json.loads(pending_dict[row_key][Config.REASON_DURATIONS_COL])
        else:
            # Fall back to the store data
            store_data = "[]"
            for data, sid in zip(stores_data, stores_ids):
                if sid.get("index") == row_key:
                    store_data = data
                    break
            existing = json.loads(store_data) if store_data else []
        
        # Remove the category
        existing = [a for a in existing if a.get("reason") != category_to_remove]
        
        # Update pending changes
        pending_dict[row_key] = {
            Config.UNIQUE_KEY: row_key,
            Config.REASON_DURATIONS_COL: json.dumps(existing),
            Config.REASONS_COL: ",".join([a["reason"] for a in existing])
        }
        
        trigger = f"remove-{row_key}-{int(datetime.datetime.now().timestamp()*1000)}"
        return json.dumps(pending_dict), trigger, f"✅ Category '{category_to_remove}' removed (unsaved)"
        
    except Exception as e:
        logger.error(f"Error removing category: {e}")
        return no_update, no_update, f"❌ Error: {str(e)}"


# =============================================================================
# Save Single Row Callback ("Update" button per row)
# =============================================================================
# Persists changes for ONE event row to the PGI_Values Dataiku dataset.
#
# This is the primary save mechanism for individual event categorization.
# When user finishes categorizing an event and clicks "Update":
#   1. Gathers current allocations (from pending changes or existing store)
#   2. Applies any duration edits the user made
#   3. Gets the comment text for this row
#   4. Calls save_annotations() to write to PGI_Values dataset
#   5. Clears this row from pending changes (now persisted)
#   6. Shows success/error message to user
#
# Data saved to PGI_Values:
#   - composite_key: Unique event identifier
#   - reason_durations: JSON array like [{"reason": "A1", "duration": 30}, ...]
#   - reasons: Comma-separated codes like "A1,B2"
#   - comment: User's free-text comment
@app.callback(
    Output("save-message-store", "data", allow_duplicate=True),
    Output("pending-changes", "data", allow_duplicate=True),
    Output("validation-message", "children", allow_duplicate=True),
    Input({"type": "save-row", "index": ALL}, "n_clicks"),
    State({"type": "save-row", "index": ALL}, "id"),
    State("pending-changes", "data"),
    State({"type": "comment", "index": ALL}, "value"),
    State({"type": "comment", "index": ALL}, "id"),
    State({"type": "allocations-store", "index": ALL}, "data"),
    State({"type": "allocations-store", "index": ALL}, "id"),
    State({"type": "edit-duration", "index": ALL, "reason": ALL}, "value"),
    State({"type": "edit-duration", "index": ALL, "reason": ALL}, "id"),
    State("machine-selector", "data"),
    prevent_initial_call=True
)
def save_single_row(save_clicks, save_ids, pending, comments, comment_ids, stores_data, stores_ids, dur_values, dur_ids, machine):
    # Check if any save button was clicked
    if not any(clicks for clicks in save_clicks if clicks):
        raise PreventUpdate
    
    trig = ctx.triggered_id
    if not isinstance(trig, dict) or trig.get("type") != "save-row":
        raise PreventUpdate
    
    row_key = trig.get("index")
    if not row_key:
        raise PreventUpdate
    
    try:
        pending_dict = json.loads(pending) if pending else {}
        
        # Get allocations for this row - check pending first, then store
        if row_key in pending_dict and Config.REASON_DURATIONS_COL in pending_dict[row_key]:
            allocations = json.loads(pending_dict[row_key][Config.REASON_DURATIONS_COL])
        else:
            store_data = "[]"
            for data, sid in zip(stores_data, stores_ids):
                if sid.get("index") == row_key:
                    store_data = data
                    break
            allocations = json.loads(store_data) if store_data else []
        
        # Apply any duration edits for this row
        for dur_val, dur_id in zip(dur_values, dur_ids):
            if dur_id.get("index") == row_key:
                reason = dur_id.get("reason")
                for alloc in allocations:
                    if alloc.get("reason") == reason and dur_val is not None:
                        alloc["duration"] = int(dur_val)
        
        # Get comment for this row
        comment = ""
        for cval, cid in zip(comments, comment_ids):
            if cid.get("index") == row_key:
                comment = cval or ""
                break
        
        # Prepare data for saving
        reasons = ",".join([a["reason"] for a in allocations])
        reason_durations = json.dumps(allocations)
        
        row_data = {
            Config.UNIQUE_KEY: row_key,
            Config.REASONS_COL: reasons,
            Config.REASON_DURATIONS_COL: reason_durations,
            Config.COMMENT_COL: comment
        }
        
        # Get machine-specific dataset names
        machine = machine or "PGI"
        ds_config = Config.get_dataset_config(machine)
        annotations_ds = ds_config["annotations"]
        events_ds = ds_config["events"]
        
        # Load existing data from annotations dataset
        try:
            existing_df = dataiku.Dataset(annotations_ds).get_dataframe()
            existing_df[Config.UNIQUE_KEY] = existing_df[Config.UNIQUE_KEY].astype(str)
        except:
            existing_df = pd.DataFrame()
        
        # Check if row exists in annotations dataset
        if not existing_df.empty and row_key in existing_df[Config.UNIQUE_KEY].values:
            # UPDATE existing row - just update annotation columns
            existing_df.loc[existing_df[Config.UNIQUE_KEY] == row_key, Config.REASONS_COL] = reasons
            existing_df.loc[existing_df[Config.UNIQUE_KEY] == row_key, Config.REASON_DURATIONS_COL] = reason_durations
            existing_df.loc[existing_df[Config.UNIQUE_KEY] == row_key, Config.COMMENT_COL] = comment
            
            # Get duration from source for status calculation
            try:
                source_df = dataiku.Dataset(events_ds).get_dataframe()
                source_df[Config.UNIQUE_KEY] = source_df[Config.UNIQUE_KEY].astype(str)
                source_row = source_df[source_df[Config.UNIQUE_KEY] == row_key]
                if not source_row.empty:
                    calc_duration = source_row.iloc[0].get(Config.DURATION_COL, 0)
                    end_time = source_row.iloc[0].get(Config.END_TIME_COL, "")
                    # Update enhanced columns
                    existing_df.loc[existing_df[Config.UNIQUE_KEY] == row_key, Config.CALCULATED_DURATION_COL] = calc_duration
                    status = calculate_categorization_status(reason_durations, calc_duration, end_time)
                    unallocated = calculate_unallocated_minutes(reason_durations, calc_duration)
                    existing_df.loc[existing_df[Config.UNIQUE_KEY] == row_key, Config.CATEGORIZATION_STATUS_COL] = status
                    existing_df.loc[existing_df[Config.UNIQUE_KEY] == row_key, Config.UNALLOCATED_MINUTES_COL] = unallocated if unallocated is not None else ""
                    existing_df.loc[existing_df[Config.UNIQUE_KEY] == row_key, Config.LAST_SYNCED_COL] = datetime.datetime.now().isoformat()
            except Exception as e:
                logger.warning(f"Could not update enhanced columns: {e}")
        else:
            # INSERT new row - get full event details from source dataset first
            try:
                source_df = dataiku.Dataset(events_ds).get_dataframe()
                source_df[Config.UNIQUE_KEY] = source_df[Config.UNIQUE_KEY].astype(str)
                source_row = source_df[source_df[Config.UNIQUE_KEY] == row_key]
                
                if not source_row.empty:
                    # Start with full event data from source
                    new_row = source_row.iloc[0].to_dict()
                    # Add annotation columns
                    new_row[Config.REASONS_COL] = reasons
                    new_row[Config.REASON_DURATIONS_COL] = reason_durations
                    new_row[Config.COMMENT_COL] = comment
                    
                    # Add enhanced annotation columns
                    calc_duration = new_row.get(Config.DURATION_COL, 0)
                    end_time = new_row.get(Config.END_TIME_COL, "")
                    new_row[Config.CALCULATED_DURATION_COL] = calc_duration
                    new_row[Config.CATEGORIZATION_STATUS_COL] = calculate_categorization_status(reason_durations, calc_duration, end_time)
                    new_row[Config.UNALLOCATED_MINUTES_COL] = calculate_unallocated_minutes(reason_durations, calc_duration)
                    new_row[Config.LAST_SYNCED_COL] = datetime.datetime.now().isoformat()
                    new_row[Config.CATEGORIZED_AT_COL] = datetime.datetime.now().isoformat()
                    
                    new_row_df = pd.DataFrame([new_row])
                else:
                    # Fallback: use just annotation data
                    new_row_df = pd.DataFrame([row_data])
            except:
                new_row_df = pd.DataFrame([row_data])
            
            existing_df = pd.concat([existing_df, new_row_df], ignore_index=True)
        
        # Write back to Dataiku using write_with_schema
        # This auto-updates the schema to include annotation columns
        all_annotation_cols = [
            Config.REASONS_COL, Config.REASON_DURATIONS_COL, Config.COMMENT_COL,
            Config.CALCULATED_DURATION_COL, Config.LAST_SYNCED_COL, 
            Config.CATEGORIZATION_STATUS_COL, Config.UNALLOCATED_MINUTES_COL,
            Config.CATEGORIZED_AT_COL
        ]
        for col in all_annotation_cols:
            if col not in existing_df.columns:
                existing_df[col] = ""
            existing_df[col] = existing_df[col].fillna("").astype(str)
        
        existing_df[Config.UNIQUE_KEY] = existing_df[Config.UNIQUE_KEY].astype(str)
        
        output_ds = dataiku.Dataset(annotations_ds)
        output_ds.write_with_schema(existing_df)
        
        # Invalidate cache so next load gets fresh data
        invalidate_cache(machine)
        
        logger.info(f"Saved row {row_key}")
        
        # Remove from pending since it's now saved
        if row_key in pending_dict:
            del pending_dict[row_key]
        
        # Calculate status for validation message
        total_allocated = sum(a.get("duration", 0) for a in allocations)
        
        # Get source duration for validation
        # Build validation message with comment confirmation
        comment_note = " (with comment)" if comment and comment.strip() else ""
        validation_msg = f"✅ Row saved{comment_note}!"
        try:
            source_df = dataiku.Dataset(events_ds).get_dataframe()
            source_df[Config.UNIQUE_KEY] = source_df[Config.UNIQUE_KEY].astype(str)
            source_row = source_df[source_df[Config.UNIQUE_KEY] == row_key]
            if not source_row.empty:
                source_duration = float(source_row.iloc[0].get(Config.DURATION_COL, 0) or 0)
                source_end_time = source_row.iloc[0].get(Config.END_TIME_COL, "")
                
                if not is_ongoing_event(source_end_time):
                    if total_allocated < source_duration:
                        unallocated = int(source_duration - total_allocated)
                        validation_msg = f"✅ Saved{comment_note}! ⚠️ {unallocated} min still unallocated"
                    elif total_allocated > source_duration:
                        over = int(total_allocated - source_duration)
                        validation_msg = f"✅ Saved{comment_note}! 🔴 {over} min over-allocated - please review"
                    else:
                        validation_msg = f"✅ Saved{comment_note}! 🟢 Fully categorized"
                else:
                    validation_msg = f"✅ Saved{comment_note}! ⏳ Event ongoing - duration will sync when completed"
        except Exception as e:
            logger.warning(f"Could not validate allocation: {e}")
        
        timestamp = datetime.datetime.now().strftime("%H:%M:%S")
        return f"Saved {row_key} at {timestamp}", json.dumps(pending_dict), validation_msg
        
    except Exception as e:
        logger.error(f"Error saving row: {e}")
        return no_update, no_update, f"❌ Error saving: {str(e)}"


# =============================================================================
# Save All Changes Callback ("Save All" button in header)
# =============================================================================
# Bulk save operation - persists ALL pending changes across ALL rows at once.
#
# When user clicks "Save All":
#   1. Collects all pending changes (category additions/removals)
#   2. Collects current comment values from all visible rows
#   3. Collects any inline duration edits
#   4. Merges everything into a single batch
#   5. Calls save_annotations() to write all to PGI_Values
#   6. Clears all pending changes
#
# This is useful when user has made changes to multiple events and wants
# to save everything in one operation rather than clicking "Update" per row.
@app.callback(
    Output("save-message-store", "data"),
    Output("pending-changes", "data", allow_duplicate=True),
    Input("save-button", "n_clicks"),
    State("pending-changes", "data"),
    State({"type": "comment", "index": ALL}, "value"),
    State({"type": "comment", "index": ALL}, "id"),
    State({"type": "edit-duration", "index": ALL, "reason": ALL}, "value"),
    State({"type": "edit-duration", "index": ALL, "reason": ALL}, "id"),
    State({"type": "allocations-store", "index": ALL}, "data"),
    State({"type": "allocations-store", "index": ALL}, "id"),
    State("machine-selector", "data"),
    prevent_initial_call=True
)
def save_all_changes(n_clicks, pending, comments, comment_ids, dur_values, dur_ids, stores_data, stores_ids, machine):
    if not n_clicks:
        raise PreventUpdate
    
    try:
        # =====================================================================
        # STEP 1: Collect all data that needs to be saved
        # =====================================================================
        annotations = {}  # Dict mapping row_key -> row data
        
        # Pull in all pending changes (from add/remove category operations)
        pending_dict = json.loads(pending) if pending else {}
        for key, data in pending_dict.items():
            annotations[key] = data
        
        # =====================================================================
        # STEP 2: Collect comments from all visible rows
        # =====================================================================
        for comment_val, comment_id in zip(comments, comment_ids):
            key = comment_id.get("index")
            if key not in annotations:
                annotations[key] = {Config.UNIQUE_KEY: key}
            annotations[key][Config.COMMENT_COL] = comment_val or ""
        
        # =====================================================================
        # STEP 3: Process any inline duration edits (user changed duration in UI)
        # =====================================================================
        # Group duration edits by row
        dur_by_row = {}
        for dur_val, dur_id in zip(dur_values, dur_ids):
            row_key = dur_id.get("index")
            reason = dur_id.get("reason")
            if row_key not in dur_by_row:
                dur_by_row[row_key] = {}
            dur_by_row[row_key][reason] = dur_val
        
        # Merge duration edits with existing allocation data from stores
        for store_data, store_id in zip(stores_data, stores_ids):
            row_key = store_id.get("index")
            if row_key in dur_by_row:
                existing = json.loads(store_data) if store_data else []
                dur_map = dur_by_row[row_key]
                # Apply each duration edit to the corresponding allocation
                for item in existing:
                    reason = item.get("reason")
                    if reason in dur_map and dur_map[reason] is not None:
                        item["duration"] = int(dur_map[reason])
                
                if row_key not in annotations:
                    annotations[row_key] = {Config.UNIQUE_KEY: row_key}
                annotations[row_key][Config.REASON_DURATIONS_COL] = json.dumps(existing)
                annotations[row_key][Config.REASONS_COL] = ",".join([a["reason"] for a in existing])
        
        if not annotations:
            return "No changes to save", "{}"
        
        # =====================================================================
        # STEP 4: Persist to Dataiku via save_annotations()
        # =====================================================================
        machine = machine or "PGI"
        result = save_annotations(list(annotations.values()), machine)
        
        # Clear pending changes after successful save
        return result, "{}"
        
    except Exception as e:
        logger.error(f"Error saving changes: {e}")
        return f"❌ Error saving: {str(e)}", no_update


