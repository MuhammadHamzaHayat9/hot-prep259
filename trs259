# =============================================================================
# Cache Configuration
# =============================================================================
# Simple time-based cache invalidation for data freshness
# Cache key changes every CACHE_TTL_MINUTES to force refresh
CACHE_TTL_MINUTES = 2  # Cache data for 2 minutes

def get_cache_key():
    """Generate cache key that changes every CACHE_TTL_MINUTES minutes."""
    now = datetime.datetime.now()
    # Round down to nearest cache interval
    cache_slot = now.minute // CACHE_TTL_MINUTES
    return f"{now.year}-{now.month}-{now.day}-{now.hour}-{cache_slot}"

