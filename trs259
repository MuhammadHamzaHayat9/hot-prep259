            if is_ongoing_event(end_time):
                duration_style["color"] = "#ed8936"
            
            # Category allocation section
            # Check pending_changes first, then fall back to session data
            selected_reasons = []
            durations_map = {}
            
            if composite_key in pending_changes and Config.REASON_DURATIONS_COL in pending_changes[composite_key]:
                # Use pending changes (user added/removed categories but hasn't saved)
                raw_rd = pending_changes[composite_key][Config.REASON_DURATIONS_COL]
            else:
                # Use original data from session
                raw_rd = row.get(Config.REASON_DURATIONS_COL, "")
            
            try:
                if raw_rd and raw_rd != "nan":
                    parsed = json.loads(raw_rd)
                    for item in parsed:
                        code = item.get("reason", "")
